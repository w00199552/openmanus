# ============================================================================
# Model provider — pick ONE of the two modes below.
# ============================================================================

# ---- Mode A: OpenAI-compatible (use this for OpenAI / Azure / OpenRouter /
#      Ollama / 公司内网兼容模型 / any "v1/chat/completions" endpoint) ----------
MODEL_PROVIDER=openai
MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-your-openai-or-company-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
# 公司内网示例（替换成实际地址，注意通常以 /v1 结尾）：
#   OPENAI_BASE_URL=http://10.x.x.x:8000/v1
#   MODEL=company-internal-model-name

# ---- Mode B: Anthropic-protocol (BigModel GLM-5.2, Anthropic, Z.ai, …) -------
# 取消注释下面 4 行，并注释掉 Mode A 的 MODEL_PROVIDER 才会启用：
# MODEL_PROVIDER=anthropic
# MODEL=GLM-5.2
# ANTHROPIC_API_KEY=your-bigmodel-key-here
# ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic

# ============================================================================
# Workspace & history (usually leave as defaults)
# ============================================================================

# --- Directory the agent operates on (real local files) --------------------
# Leave blank / unset to default to the server's current working directory.
WORKDIR=

# --- Conversation history persistence (checkpointer) -----------------------
# SQLite (default, zero-dependency):
DATABASE_URL=sqlite:///./data/checkpoints.db
# Postgres (optional): postgresql+psycopg://user:pass@host:5432/openmanus

# --- Server ----------------------------------------------------------------
HOST=127.0.0.1
PORT=8000
CORS_ORIGINS=*
